# ============================================================
# ROOT .gitignore — portfolio-webpage monorepo
# ============================================================

# ----- Secrets / Environment (CRITICAL) ----------------------
.env
.env.local
.env.*.local
.env.production
.env.development
# Allow the example template
!.env.example

# ----- Python / FastAPI (portfolio-api) ----------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.log
logs/

# ----- Node / Next.js (portfolio-frontend) -------------------
node_modules/
.next/
out/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Editor / OS ------------------------------------------
.DS_Store
*.pem
.vscode/
.idea/
*.tsbuildinfo
*.sw[op]
Thumbs.db

# ----- Vercel / Render artifacts ----------------------------
.vercel
