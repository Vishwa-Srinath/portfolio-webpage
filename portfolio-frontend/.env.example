# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# For production, set these in the Vercel dashboard under:
#   Project Settings > Environment Variables
#
# NEXT_PUBLIC_* variables are embedded into the browser bundle
# (they are visible to end users) — never put secrets here.
# ─────────────────────────────────────────────────────────────

# The base URL of your deployed FastAPI backend (Render)
# Local:      http://localhost:8000
# Production: https://portfolio-api.onrender.com  (your Render service URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase — only needed if the frontend queries Supabase directly
# (e.g., for fetching public content). Get from Supabase > Settings > API.
# NEXT_PUBLIC_SUPABASE_URL=https://[project-id].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Sentry — frontend error tracking (optional)
# Get DSN from sentry.io > Settings > Projects > [your-project] > Client Keys
# NEXT_PUBLIC_SENTRY_DSN=https://[key]@[org].ingest.sentry.io/[id]
